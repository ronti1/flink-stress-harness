{
  "uid": "flink-stress-harness",
  "title": "Flink Stress Harness",
  "tags": ["flink", "stress", "regression"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Source throughput (records/sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(flink_taskmanager_job_task_numRecordsOutPerSecond{task_name=~\".*synthetic.source.*\"})",
          "legendFormat": "source out/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "End-to-end processed throughput (records/sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(flink_taskmanager_job_task_operator_processedRecordsPerSec{operator_name=~\".*latency.sink.*\"})",
          "legendFormat": "processed/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "End-to-end latency (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(flink_taskmanager_job_task_operator_e2eLatencyMs{operator_name=~\".*latency.sink.*\",quantile=\"0.5\"})",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(flink_taskmanager_job_task_operator_e2eLatencyMs{operator_name=~\".*latency.sink.*\",quantile=\"0.99\"})",
          "legendFormat": "p99"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(flink_taskmanager_job_task_operator_e2eLatencyMs{operator_name=~\".*latency.sink.*\",quantile=\"0.999\"})",
          "legendFormat": "p999"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Backpressure & busy time (ms/sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ms", "max": 1000 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(flink_taskmanager_job_task_busyTimeMsPerSecond)",
          "legendFormat": "busy (max)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(flink_taskmanager_job_task_backPressuredTimeMsPerSecond)",
          "legendFormat": "backpressured (max)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "TaskManager CPU load (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * avg(flink_taskmanager_Status_JVM_CPU_Load)",
          "legendFormat": "tm cpu %"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "TaskManager heap used (bytes)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(flink_taskmanager_Status_JVM_Memory_Heap_Used)",
          "legendFormat": "heap used"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Checkpoint duration (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(flink_jobmanager_job_lastCheckpointDuration)",
          "legendFormat": "last checkpoint duration"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Job restarts (recovery signal)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(flink_jobmanager_job_numRestarts)",
          "legendFormat": "restarts"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Completed checkpoints",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(flink_jobmanager_job_numberOfCompletedCheckpoints)",
          "legendFormat": "completed"
        }
      ]
    }
  ]
}
